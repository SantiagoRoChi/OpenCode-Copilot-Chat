{
  "name": "opencode-zen-copilot",
  "displayName": "OpenCode Zen for Copilot",
  "description": "Access OpenCode Zen models in GitHub Copilot Chat — free models included",
  "version": "2.3.0",
  "publisher": "SantiagoRomanChillon",
  "icon": "assets/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SantiagoRoChi/OpenCode-Copilot-Chat"
  },
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "AI",
    "Machine Learning",
    "Chat"
  ],
  "keywords": [
    "opencode",
    "zen",
    "go",
    "free",
    "models",
    "copilot",
    "ai",
    "llm",
    "chat"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run esbuild-base -- --minify",
    "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --target=es2020",
    "esbuild": "npm run esbuild-base -- --sourcemap",
    "esbuild-watch": "npm run esbuild-base -- --sourcemap --watch",
    "test-compile": "tsc -p ./",
    "lint": "eslint \"src/**/*.ts\"",
    "test-build": "tsc -p tsconfig.test.json",
    "test": "npm run test-build && node --test \"out-test/__tests__/*.test.js\"",
    "deploy": "vsce publish --no-yarn",
    "package": "vsce package --no-yarn"
  },
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "opencode-free",
        "displayName": "OpenCode Free",
        "configuration": {
          "properties": {
            "apiKey": {
              "type": "string",
              "secret": true,
              "title": "OpenCode API Key",
              "description": "Uses Zen API key. Get one at opencode.ai/auth."
            }
          }
        }
      },
      {
        "vendor": "opencode-go",
        "displayName": "OpenCode Go",
        "configuration": {
          "properties": {
            "apiKey": {
              "type": "string",
              "secret": true,
              "title": "OpenCode Go API Key",
              "description": "API key from opencode.ai/auth for Go subscription."
            }
          }
        }
      },
      {
        "vendor": "opencode-zen",
        "displayName": "OpenCode Zen",
        "configuration": {
          "properties": {
            "apiKey": {
              "type": "string",
              "secret": true,
              "title": "OpenCode Zen API Key",
              "description": "API key from opencode.ai/auth. Auto-detected from OpenCode if installed."
            }
          }
        }
      }
    ],
    "commands": [
      {
        "command": "opencode-zen.configureZen",
        "title": "Configure Zen Key",
        "category": "OpenCode Zen"
      },
      {
        "command": "opencode-zen.configureGo",
        "title": "Configure Go Key",
        "category": "OpenCode Zen"
      },
      {
        "command": "opencode-zen.refreshAll",
        "title": "Refresh All Models",
        "category": "OpenCode Zen"
      },
      {
        "command": "opencode-zen.showOutput",
        "title": "Show Output",
        "category": "OpenCode Zen"
      },
      {
        "command": "opencode-zen.showUsage",
        "title": "Show Usage Stats",
        "category": "OpenCode Zen"
      },
      {
        "command": "opencode-zen.showOutputLog",
        "title": "Show Output Log",
        "category": "OpenCode Zen"
      },
      {
        "command": "opencode-zen.clearUsage",
        "title": "Clear Usage Stats",
        "category": "OpenCode Zen"
      },
      {
        "command": "opencode-zen.showGlobal",
        "title": "Show Global Usage",
        "category": "OpenCode Zen"
      },
      {
        "command": "opencode-zen.showConfig",
        "title": "Show Configuration",
        "category": "OpenCode Zen"
      },
      {
        "command": "opencode-zen.refreshGlobal",
        "title": "Refresh Global Usage",
        "category": "OpenCode Zen"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "opencode-zen-sidebar",
          "title": "OpenCode Zen",
          "icon": "$(check)"
        }
      ]
    },
    "views": {
      "opencode-zen-sidebar": [
        {
          "id": "opencode-zen-session-tree",
          "type": "tree",
          "name": "Session"
        },
        {
          "id": "opencode-zen-global-tree",
          "type": "tree",
          "name": "Global"
        },
        {
          "id": "opencode-zen-config-tree",
          "type": "tree",
          "name": "Config"
        }
      ]
    },
    "configuration": {
      "title": "OpenCode Zen",
      "properties": {
        "opencode-zen.requestTimeout": {
          "type": "number",
          "default": 60000,
          "description": "Request timeout in milliseconds"
        },
        "opencode-zen.enableToolCalling": {
          "type": "boolean",
          "default": true,
          "description": "Enable tool calling capability for models"
        },
        "opencode-zen.enableImageInput": {
          "type": "boolean",
          "default": true,
          "description": "Enable image input capability for models that support multimodal"
        },
        "opencode-zen.agentTemperature": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 2,
          "description": "Temperature for agent/tool calling mode (lower = more consistent)"
        },
        "opencode-zen.parallelToolCalling": {
          "type": "boolean",
          "default": true,
          "description": "Allow model to call multiple tools in parallel"
        },
        "opencode-zen.verboseLogging": {
          "type": "boolean",
          "default": false,
          "description": "Log full request body to output channel (debug only)"
        },
        "opencode-zen.autoDetectOpenCode": {
          "type": "boolean",
          "default": true,
          "description": "Auto-detect OpenCode installation and use its API key"
        }
      }
    },
    "menus": {
      "view/item/context": [
        {
          "view": "opencode-zen-config-tree",
          "command": "opencode-zen.configureZen"
        },
        {
          "view": "opencode-zen-config-tree",
          "command": "opencode-zen.configureGo"
        },
        {
          "view": "opencode-zen-config-tree",
          "command": "opencode-zen.refreshAll"
        },
        {
          "view": "opencode-zen-config-tree",
          "command": "opencode-zen.clearUsage"
        },
        {
          "view": "opencode-zen-global-tree",
          "command": "opencode-zen.refreshGlobal"
        }
      ]
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.120.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.0",
    "sharp": "^0.34.5",
    "typescript": "^5.6.0"
  }
}

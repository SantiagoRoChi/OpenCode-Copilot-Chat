{
  "name": "plus-providers-copilot-chat",
  "displayName": "+ Providers on Copilot Chat",
  "description": "Connect LM Studio, Ollama, and OpenCode servers to GitHub Copilot Chat — local and remote AI models",
  "version": "3.5.0",
  "publisher": "SantiagoRomanChillon",
  "icon": "assets/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SantiagoRoChi/OpenCode-Copilot-Chat"
  },
  "engines": {
    "vscode": "^1.120.0"
  },
  "enabledApiProposals": [
    "chatProvider",
    "languageModelThinkingPart",
    "chatInputNotification",
    "chatStatusItem",
    "languageModelPricing",
    "languageModelSystem"
  ],
  "categories": [
    "AI",
    "Machine Learning",
    "Chat"
  ],
  "keywords": [
    "lmstudio",
    "ollama",
    "opencode",
    "local-ai",
    "self-hosted",
    "remote-server",
    "copilot",
    "ai",
    "llm",
    "chat",
    "models",
    "reasoning",
    "vision",
    "tools"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run esbuild-base -- --minify",
    "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --target=es2020",
    "esbuild": "npm run esbuild-base -- --sourcemap",
    "esbuild-watch": "npm run esbuild-base -- --sourcemap --watch",
    "test-compile": "tsc -p ./",
    "lint": "eslint \"src/**/*.ts\"",
    "test-build": "tsc -p tsconfig.test.json",
    "test": "vscode-test",
    "test:node": "npx tsx test/provider-behavior.test.ts",
    "deploy": "vsce publish --no-yarn",
    "package": "vsce package --no-yarn"
  },
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "opencode-free",
        "displayName": "OpenCode Free",
        "configuration": {
          "properties": {
            "apiKey": {
              "type": "string",
              "secret": true,
              "title": "OpenCode API Key",
              "description": "Uses Zen API key. Get one at opencode.ai/auth."
            }
          }
        }
      },
      {
        "vendor": "opencode-go",
        "displayName": "OpenCode Go",
        "configuration": {
          "properties": {
            "apiKey": {
              "type": "string",
              "secret": true,
              "title": "OpenCode Go API Key",
              "description": "API key from opencode.ai/auth for Go subscription."
            }
          }
        }
      },
      {
        "vendor": "opencode-zen",
        "displayName": "OpenCode Zen",
        "configuration": {
          "properties": {
            "apiKey": {
              "type": "string",
              "secret": true,
              "title": "OpenCode Zen API Key",
              "description": "API key from opencode.ai/auth. Auto-detected from OpenCode if installed."
            }
          }
        }
      },
      {
        "vendor": "opencode-server",
        "displayName": "OpenCode Servers",
        "configuration": {}
      },
      {
        "vendor": "lmstudio",
        "displayName": "LM Studio",
        "configuration": {
          "properties": {
            "baseUrl": {
              "type": "string",
              "title": "LM Studio Server URL",
              "description": "Base URL of your LM Studio server (e.g. http://localhost:1234)",
              "default": "http://localhost:1234"
            }
          }
        }
      },
      {
        "vendor": "ollama-plus",
        "displayName": "Ollama+",
        "configuration": {
          "properties": {
            "baseUrl": {
              "type": "string",
              "title": "Ollama Server URL",
              "description": "Base URL of your Ollama server (e.g. http://localhost:11434)",
              "default": "http://localhost:11434"
            }
          }
        }
      }
    ],
    "languageModelTools": [
      {
        "name": "opencode_subagent",
        "displayName": "OpenCode Subagent",
        "modelDescription": "Execute a subagent task using an OpenCode provider. Delegates to the first available OpenCode provider (Free, Go, Zen, or Server).",
        "toolReferenceName": "opencode_subagent",
        "inputSchema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "What to execute — can include commands or task descriptions"
            },
            "description": {
              "type": "string",
              "description": "User-visible description shown while the tool runs"
            }
          },
          "required": [
            "query",
            "description"
          ]
        }
      }
    ],
    "commands": [
      {
        "command": "opencode-zen.configureZen",
        "title": "Configure Zen Key",
        "category": "OpenCode Zen"
      },
      {
        "command": "opencode-zen.configureGo",
        "title": "Configure Go Key",
        "category": "OpenCode Zen"
      },
      {
        "command": "opencode-zen.refreshAll",
        "title": "Refresh All Models",
        "category": "OpenCode Zen"
      },
      {
        "command": "opencode-zen.showOutput",
        "title": "Show Output",
        "category": "OpenCode Zen"
      },
      {
        "command": "opencode-zen.showUsage",
        "title": "Show Usage Stats",
        "category": "OpenCode Zen"
      },
      {
        "command": "opencode-zen.showOutputLog",
        "title": "Show Output Log",
        "category": "OpenCode Zen"
      },
      {
        "command": "opencode-zen.clearUsage",
        "title": "Clear Usage Stats",
        "category": "OpenCode Zen"
      },
      {
        "command": "opencode-zen.refreshGlobal",
        "title": "Refresh Global Usage",
        "category": "OpenCode Zen"
      },
      {
        "command": "opencode-zen.addServer",
        "title": "Add Server",
        "category": "OpenCode Zen"
      },
      {
        "command": "opencode-zen.editServer",
        "title": "Edit Server",
        "category": "OpenCode Zen"
      },
      {
        "command": "opencode-zen.removeServer",
        "title": "Remove Server",
        "category": "OpenCode Zen"
      },
      {
        "command": "opencode-zen.launchServer",
        "title": "Launch Server",
        "category": "OpenCode Zen"
      },
      {
        "command": "opencode-zen.refreshServers",
        "title": "Refresh Servers",
        "category": "OpenCode Zen"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "opencode-zen-sidebar",
          "title": "OpenCode Zen",
          "icon": "$(check)"
        }
      ]
    },
    "views": {
      "opencode-zen-sidebar": [
        {
          "id": "opencode-zen-tree",
          "name": "OpenCode Zen"
        },
        {
          "type": "webview",
          "id": "opencode-zen-dashboard",
          "name": "OpenCode Dashboard"
        }
      ]
    },
    "configuration": {
      "title": "OpenCode Zen",
      "properties": {
        "opencode-zen.requestTimeout": {
          "type": "number",
          "default": 60000,
          "description": "Request timeout in milliseconds"
        },
        "opencode-zen.enableToolCalling": {
          "type": "boolean",
          "default": true,
          "description": "Enable tool calling capability for models"
        },
        "opencode-zen.enableImageInput": {
          "type": "boolean",
          "default": true,
          "description": "Enable image input capability for models that support multimodal"
        },
        "opencode-zen.agentTemperature": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 2,
          "description": "Temperature for agent/tool calling mode (lower = more consistent)"
        },
        "opencode-zen.parallelToolCalling": {
          "type": "boolean",
          "default": true,
          "description": "Allow model to call multiple tools in parallel"
        },
        "opencode-zen.verboseLogging": {
          "type": "boolean",
          "default": false,
          "description": "Log full request body to output channel (debug only)"
        },
        "opencode-zen.autoDetectOpenCode": {
          "type": "boolean",
          "default": true,
          "description": "Auto-detect OpenCode installation and use its API key"
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "view": "opencode-zen-dashboard",
          "command": "opencode-zen.addServer",
          "when": "view == opencode-zen-dashboard"
        },
        {
          "view": "opencode-zen-dashboard",
          "command": "opencode-zen.refreshAll",
          "when": "view == opencode-zen-dashboard"
        }
      ]
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.0",
    "sharp": "^0.34.5",
    "tsx": "^4.22.4",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.85",
    "@ai-sdk/openai": "^3.0.73",
    "@opencode-ai/sdk": "^1.17.3",
    "ai": "^6.0.208"
  }
}
